void setup() {

  Serial.begin(115200);

  pinMode(ir, INPUT);
  pinMode(moisture, INPUT);
  delay(2000);

  // ================= WIFI MANAGER =================
  WiFiManager wm;

  bool res;
  res = wm.autoConnect("ESP32-SETUP");

  if (!res)
  {
    Serial.println("WiFi Failed");
    ESP.restart();
  }
  else
  {
    Serial.println("WiFi Connected");
  }

  //  // ================= BLYNK =================

  Blynk.begin(BLYNK_AUTH_TOKEN, WiFi.SSID().c_str(), WiFi.psk().c_str());


  Serial.println("DONE");

  dustServo.attach(Servo_1);
  chocolateServo.attach(Servo_2);
  holdServo.attach(Servo_3);

  dustServo.write(90);
  chocolateServo.write(0);
  holdServo.write(0);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED not detected");
    while (true);
  }

  display.clearDisplay();
  display.setTextSize(2);
  display.setTextColor(WHITE);
  display.setCursor(20, 20);
  display.println("READY");
  display.display();


}

void loop() {
  Blynk.run();
  int irState = digitalRead(ir);

  // ------------------ OBJECT DETECT ------------------
  if (irState == LOW && !objectDetected) {

    objectDetected = true;
    detectTime = millis();

    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(10, 20);
    display.println("Object Found");
    display.setCursor(10, 35);
    display.println("Checking...");
    display.display();
  }

  // ------------------ MOISTURE CHECK ------------------
  if (objectDetected && millis() - detectTime > 4000) {

    int moistureState = digitalRead(moisture);

    display.clearDisplay();
    if (moistureState == LOW) {
      dustServo.write(25);  // WET
      display.drawBitmap(0, 0, epd_bitmap_test__3_, 128, 64, WHITE);
    } else {
      dustServo.write(155);  // DRY
      display.drawBitmap(0, 0, epd_bitmap_test__3_, 128, 64, WHITE);
    }
    delay(2000);
    dustServo.write(90);  // back to center
    display.display();
    delay(5000);



    display.clearDisplay();
    display.setCursor(10, 20);
    display.println("Thank You");
    display.setCursor(20, 20);
    display.println("Collect your Chocolate");
    display.display();

    delay(1500);

    display.clearDisplay();
    display.display();

    objectDetected = false;
    //dustProcessed = true;
    actionTime = millis();
  }


  // ------------------ IDLE DISPLAY ------------------
  if (!objectDetected &&  !blynkPermission) {
    display.setTextSize(1);
    display.setCursor(0, 0);
    display.print("Waiting for Garbage");
    display.display();
  }
  // 🔥 BLYNK CONDITION
  if (blynkPermission)
  {
    releaseChocolate();
  }
}


// ================= CHOCOLATE FUNCTION =================
void releaseChocolate()
{
  display.clearDisplay();
  display.setCursor(10, 20);
  display.println("Take Chocolate");
  display.display();

  // Servo 1
  chocolateServo.write(90);
  delay(1000);
  chocolateServo.write(0);

  delay(1000);

  // Servo 2
  holdServo.write(90);
  delay(1000);
  holdServo.write(0);

  display.clearDisplay();
  display.setCursor(10, 20);
  display.println("Done");
  display.display();

  // 🔥 RESET V0
  Blynk.virtualWrite(V0, 0);
  blynkPermission = false;

  Serial.println("V0 Reset Done");
}
